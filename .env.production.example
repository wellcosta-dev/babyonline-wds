NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Auth
AUTH_SESSION_SECRET=replace-with-long-random-secret
ADMIN_EMAIL=admin@your-domain.hu

# Database (for docker-compose.prod.yml postgres service)
POSTGRES_DB=babyonline
POSTGRES_USER=babyonline
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql://babyonline:replace-with-strong-db-password@postgres:5432/babyonline?schema=public

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional analytics
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=

# Shipping / billing integrations
GLS_API_BASE_URL=
GLS_API_KEY=
POSTA_API_BASE_URL=
POSTA_API_KEY=
BILLINGO_API_BASE_URL=https://api.billingo.hu/v3
BILLINGO_API_KEY=
