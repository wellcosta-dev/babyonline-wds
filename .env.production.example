NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Domain / app URL
NEXT_PUBLIC_SITE_URL=https://babyonline.hu

# Admin + auth
ADMIN_EMAIL=hello@babyonline.hu
AUTH_SESSION_SECRET=replace-with-a-long-random-secret

# Database (used by docker-compose postgres service)
POSTGRES_DB=babyonline
POSTGRES_USER=babyonline
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql://babyonline:change-this-db-password@postgres:5432/babyonline?schema=public

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Analytics (optional)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=

# Shipping / billing integrations (optional if not in use yet)
GLS_API_BASE_URL=
GLS_API_KEY=
POSTA_API_BASE_URL=
POSTA_API_KEY=
BILLINGO_API_BASE_URL=https://api.billingo.hu/v3
BILLINGO_API_KEY=

